---
import Search from 'virtual:starlight/components/Search';

const baseUrl = import.meta.env.BASE_URL;
const documentationHref = `${baseUrl}documentation/`;
const changelogHref = `${baseUrl}documentation/project/changelog/`;
const githubHref = 'https://github.com/eventsalsa/store';
const pathname = Astro.url.pathname;
const isChangelog = pathname.startsWith(changelogHref);
const isDocs = pathname.startsWith(documentationHref) && !isChangelog;
---

<div class="docs-topbar">
	<div class="docs-topbar-left">
		<a class="docs-brand brand-font" href={baseUrl}>eventsalsa</a>
		<nav class="docs-desktop-nav" aria-label="Primary">
			<a class:list={{ 'is-active': isDocs }} href={documentationHref}>Docs</a>
			<a class:list={{ 'is-active': isChangelog }} href={changelogHref}>Changelog</a>
		</nav>
	</div>
	<div class="docs-topbar-actions">
		<Search class="docs-search" />
		<a class="docs-github-link" href={githubHref} aria-label="GitHub">
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path d="M12 1.5A10.5 10.5 0 0 0 8.68 22c.53.1.72-.23.72-.51v-1.8c-2.93.64-3.55-1.24-3.55-1.24-.48-1.2-1.16-1.52-1.16-1.52-.95-.65.07-.64.07-.64 1.05.08 1.61 1.08 1.61 1.08.94 1.6 2.47 1.14 3.07.87.09-.68.37-1.14.67-1.41-2.34-.27-4.8-1.17-4.8-5.22 0-1.15.41-2.09 1.08-2.83-.11-.27-.47-1.36.11-2.84 0 0 .88-.28 2.89 1.08a9.93 9.93 0 0 1 5.26 0c2.01-1.36 2.89-1.08 2.89-1.08.58 1.48.22 2.57.11 2.84.67.74 1.08 1.68 1.08 2.83 0 4.06-2.47 4.94-4.83 5.2.38.33.72.99.72 2v2.97c0 .28.19.61.73.51A10.5 10.5 0 0 0 12 1.5Z" />
			</svg>
		</a>
		<button class="docs-theme-toggle" data-theme-toggle type="button">
			<span class="material-symbols-outlined" data-theme-icon>light_mode</span>
		</button>
	</div>
</div>

<script is:inline>
	(() => {
		const storageKey = 'starlight-theme';
		const getResolvedTheme = () => {
			const stored = typeof localStorage !== 'undefined' ? localStorage.getItem(storageKey) : null;
			if (stored === 'light' || stored === 'dark') return stored;
			return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
		};

		const applyTheme = (theme) => {
			const resolved = theme === 'light' ? 'light' : 'dark';
			document.documentElement.dataset.theme = resolved;
			document.documentElement.style.colorScheme = resolved;
			document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
				const label = resolved === 'light' ? 'Switch to dark mode' : 'Switch to light mode';
				button.setAttribute('aria-label', label);
				button.setAttribute('title', label);
				const icon = button.querySelector('[data-theme-icon]');
				if (icon) icon.textContent = resolved === 'light' ? 'dark_mode' : 'light_mode';
			});
			if (window.StarlightThemeProvider) {
				window.StarlightThemeProvider.updatePickers(resolved);
			}
		};

		const persistTheme = (theme) => {
			if (typeof localStorage !== 'undefined') {
				localStorage.setItem(storageKey, theme);
			}
			applyTheme(theme);
		};

		applyTheme(getResolvedTheme());

		document.addEventListener('DOMContentLoaded', () => {
			applyTheme(getResolvedTheme());
		});

		document.addEventListener('click', (event) => {
			const button = event.target.closest('[data-theme-toggle]');
			if (!button) return;
			const nextTheme = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
			persistTheme(nextTheme);
		});

		window.addEventListener('storage', (event) => {
			if (event.key !== storageKey) return;
			applyTheme(getResolvedTheme());
		});
	})();
</script>

---
import SiteLayout from '../layouts/SiteLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
---

<SiteLayout title="Page not found | eventsalsa">
	<main class="shell">
		<p class="eyebrow">404</p>
		<h1>Page not found</h1>
		<p class="lead">
			The requested page does not exist yet or has moved while the eventsalsa site is still being
			assembled.
		</p>
		<div class="actions">
			<a class="primary" href={baseUrl}>Back to home</a>
			<a class="secondary" href={`${baseUrl}documentation/`}>Open documentation</a>
		</div>
	</main>
</SiteLayout>

<style>
	.shell {
		max-width: 48rem;
		margin: 0 auto;
		padding: 5rem 1.5rem;
	}

	.eyebrow {
		margin: 0 0 0.75rem;
		font-size: 0.85rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #93c5fd;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.25rem, 7vw, 4rem);
	}

	.lead {
		margin: 1rem 0 0;
		line-height: 1.7;
		color: #cbd5e1;
	}

	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 1.5rem;
	}

	.actions a {
		border-radius: 999px;
		padding: 0.8rem 1.15rem;
		text-decoration: none;
		font-weight: 600;
	}

	.primary {
		background: #818cf8;
		color: #111827;
	}

	.secondary {
		border: 1px solid rgba(199, 210, 254, 0.28);
		background: rgba(15, 23, 42, 0.45);
		color: #e2e8f0;
	}
</style>
